
PORT=3000
MONGODB_URI=mongodb://localhost:27017/auth_demo
NODE_ENV=development

# Sessions
SESSION_SECRET=your_session_secret_here_change_me

# JWT
JWT_SECRET=your_jwt_secret_here_change_me
JWT_EXPIRY=15m
REFRESH_TOKEN_SECRET=your_refresh_token_secret_here_change_me
REFRESH_TOKEN_EXPIRY=7d

# Redis (optionnel, si vous utilisez Redis pour les sessions)
REDIS_HOST=localhost
REDIS_PORT=6379